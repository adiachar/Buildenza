# MongoDB Atlas via Prisma Accelerate (required for Cloudflare Edge deployment)
# 1. Go to https://console.prisma.io/ and create a project
# 2. Connect your MongoDB Atlas cluster in Prisma Console
# 3. Copy the Accelerate connection string below
DATABASE_URL="prisma+mongodb://accelerate.prisma.io/?api_key=YOUR_PRISMA_ACCELERATE_API_KEY"

# Your original MongoDB Atlas URL (used by Prisma Accelerate to connect to your database)
DIRECT_DATABASE_URL="mongodb+srv://<username>:<password>@<cluster-url>/<database>?retryWrites=true&w=majority"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-key-here"

# Google OAuth Providers (Optional but recommended)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Razorpay Configuration
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="..."
