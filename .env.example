# User data is now stored in JSON files (users.json) - no database required!
# This makes deployment much simpler and works perfectly with Cloudflare Edge runtime.

# NextAuth Configuration
NEXTAUTH_URL="https://buildenza.pages.dev"
NEXTAUTH_SECRET="generate-a-random-secret-key-here"

# Google OAuth Providers (Optional but recommended)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Razorpay Configuration
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="..."

# Stripe Configuration (for premium subscriptions)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
